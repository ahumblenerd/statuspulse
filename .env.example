# StatusPulse Configuration

# Database (SQLite default, set DATABASE_URL for Postgres)
DATABASE_PATH=./data/statuspulse.db
# DATABASE_URL=postgres://user:pass@localhost:5432/statuspulse

# Restate
RESTATE_ADMIN_URL=http://localhost:9070
RESTATE_INGRESS_URL=http://localhost:8080

# API
API_PORT=3000
MCP_PORT=3001
RESTATE_PORT=9080

# Auth (none | api-key | bearer)
AUTH_MODE=none
API_KEY=changeme

# Alerts
SLACK_WEBHOOK_URL=
WEBHOOK_SECRET=your-hmac-secret

# Claude Vision (for image-based vendor detection)
ANTHROPIC_API_KEY=

# Polling
DEFAULT_POLL_INTERVAL_SECONDS=120
